race = race
)
# Create graph (directed, since endorsements have direction)
g <- graph_from_data_frame(d=edge_list, vertices= vertices, directed=TRUE)
######################################
# 2. Set node colors by gender
V(g)$color <- ifelse(V(g)$gender == "Female", "hotpink", "dodgerblue")
V(g)$shape <- ifelse(V(g)$race == "White", "triangle", "circle")
# 3. Set edge width proportional to number of endorsements
E(g)$width <- edge_list$weight
# 4. Set some layout (Fruchterman-Reingold or Kamada-Kawai works well)
layout <- layout_with_fr(g)
# 5. Plot
set.seed(123)
plot(g,
layout = layout,
vertex.label = NA,
vertex.size = 5,
edge.arrow.size = 0.4,
main = "Endorsement Network by Gender\n(Pink = Female, Thicker Arrows = More Endorsements)")
# Create graph (directed, since endorsements have direction)
g <- graph_from_data_frame(d=edge_list, vertices=data.frame(name=nodes, gender=gender), directed=TRUE)
######################################
# 2. Set node colors by gender
V(g)$color <- ifelse(V(g)$gender == "Female", "hotpink", "dodgerblue")
V(g)$shape <- ifelse(V(g)$race == "White", "triangle", "circle")
# 3. Set edge width proportional to number of endorsements
E(g)$width <- edge_list$weight
# 4. Set some layout (Fruchterman-Reingold or Kamada-Kawai works well)
layout <- layout_with_fr(g)
# 5. Plot
set.seed(123)
plot(g,
layout = layout,
vertex.label = NA,
vertex.size = 5,
edge.arrow.size = 0.4,
main = "Endorsement Network by Gender\n(Pink = Female, Thicker Arrows = More Endorsements)")
