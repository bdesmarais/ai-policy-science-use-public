library(stringr)
library(fs)
library(readr)
library(dplyr)
library(tibble)
# Define the directory containing the press releases
input_dir <- "~/OneDrive - The Pennsylvania State University/SGRA_2025/Dem_texts"
# Create output folders
out <- "~/OneDrive - The Pennsylvania State University/SGRA_2025"
output_dir <- file.path(out, "AI_related")
dir_create(output_dir)
####################################
################## Keywords Lists
####################################
# Create AI related keyword terms as standalone terms
ai_keywords <- c(
"artificial intelligence", "AI", "machine learning", "ML",
"deep learning", "neural network", "computer vision",
"natural language processing", "NLP",
"large language model", "LLM",
"foundation model", "generative AI", "genAI", "chatbot",
"algorithm", "automated reasoning",
# products
"ChatGPT", "GPT-\\d+(\\.\\d+)?", "OpenAI",
"Claude( \\d+)?", "Anthropic",
"Gemini( \\d+)?", "Google AI", "PaLM 2",
"Llama ?\\d+(\\.\\d+)?", "Meta AI",
"Mistral( \\d+)?", "Mixtral",
"Cohere", "Command R(\\+)?",
"Copilot( \\w+)?", "GitHub Copilot",
"Midjourney", "Stable Diffusion", "DALL·E|DALLE",
# ai_ethics
"AI safety", "AI governance", "AI policy", "AI ethics",
"algorithmic bias", "algorithmic fairness", "model oversight",
"automated (employment|hiring) decision(s)?",
"facial recognition", "model transparency", "responsible AI"
)
####################################
################## Regular Expressions
####################################
pattern <- paste0("\\b(", paste(ai_keywords, collapse = "|"), ")\\b")
# Get all .txt files in the directory (non-recursive; set `recurse = TRUE` if needed)
txt_files <- dir_ls(input_dir, regexp = "\\.txt$", recurse = FALSE)
####################################
################## Search ONLY Files
####################################
# Loop over files and copy those containing AI keywords
for (file in txt_files) {
text <- tolower(readLines(file, warn = FALSE)) |> paste(collapse = " ")
if (str_detect(text, regex(pattern, ignore_case = TRUE))) {
file_copy(file, output_dir, overwrite = TRUE)
}
}
# Snippet settings
max_snippets  <- 3      # how many snippets per file
context_chars <- 90     # characters of context on each side
summary_file  <- file.path(output_dir, "ai_snippets_summary.txt")
# reset summary file each run
if (file_exists(summary_file)) file_delete(summary_file)
# Loop over files and copy those containing AI keywords + write snippets
for (file in txt_files) {
# read once; keep original for snippets, lowercase for detection (as you had it)
raw_text <- paste(readLines(file, warn = FALSE, encoding = "UTF-8"), collapse = " ")
text     <- tolower(raw_text)
if (str_detect(text, regex(pattern, ignore_case = FALSE))) {
# copy matched file
file_copy(file, output_dir, overwrite = TRUE)
# find match locations on the original text (so snippets keep original casing)
locs <- str_locate_all(raw_text, regex(pattern, ignore_case = TRUE))[[1]]
if (nrow(locs) > 0) {
# take up to max_snippets, spaced to avoid near-duplicates
take <- integer(0)
last_end <- -Inf
for (i in seq_len(nrow(locs))) {
if (locs[i, 1] > last_end) {
take <- c(take, i)
last_end <- locs[i, 2] + context_chars
if (length(take) >= max_snippets) break
}
}
locs <- locs[take, , drop = FALSE]
# build snippets
snips <- character(nrow(locs))
for (i in seq_len(nrow(locs))) {
s <- max(1, locs[i, 1] - context_chars)
e <- min(nchar(raw_text), locs[i, 2] + context_chars)
snippet <- substr(raw_text, s, e)
snippet <- gsub("\\s+", " ", snippet)  # compact whitespace
snips[i] <- paste0("… ", snippet, " …")
}
# append to summary file
cat(
sprintf("FILE: %s\n", file),
paste0(sprintf("  - Snippet %d: ", seq_along(snips)), snips, collapse = "\n"),
"\n\n",
file = summary_file, append = TRUE
)
}
}
}
